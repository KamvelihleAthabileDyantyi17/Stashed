<?xml version="1.0" encoding="utf-8"?>
<!-- Sharp Editorial card: 2px black border, flat 4px offset shadow via layer-list -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer (flat / hard-edged) -->
    <item android:left="4dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#111111"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>
    <!-- Card surface -->
    <item android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
            <stroke android:width="2dp" android:color="#111111"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>
</layer-list>
