<?xml version="1.0" encoding="utf-8"?>
<!-- Goal RecyclerView item card -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="14dp"
    android:layout_marginBottom="12dp"
    android:layout_marginEnd="4dp">

    <!-- Name + status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvGoalName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IN PROGRESS"
            android:textColor="@color/textSecondary"
            android:textSize="9sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progressGoal"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:max="100"
        android:progress="0"
        android:progressBackgroundTint="@color/progressTrack"
        android:progressTint="@color/black"/>

    <!-- Saved + Target + Percent -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvSaved"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvTarget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:textColor="@color/textSecondary"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvGoalPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Deadline -->
    <TextView
        android:id="@+id/tvDeadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/textMuted"
        android:textSize="11sp"/>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContribute"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/btn_contribute"
            android:backgroundTint="@color/black"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            app:cornerRadius="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_delete"
            android:backgroundTint="@color/offWhite"
            android:textColor="@color/semanticDanger"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            app:strokeColor="@color/semanticDanger"
            app:strokeWidth="1.5dp"
            app:cornerRadius="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

</LinearLayout>
