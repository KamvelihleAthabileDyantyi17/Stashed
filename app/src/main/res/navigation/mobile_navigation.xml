<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/nav_splash">

    <!-- Splash -->
    <fragment
        android:id="@+id/nav_splash"
        android:name="com.example.stashed.ui.splash.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@+id/nav_login"
            app:popUpTo="@+id/nav_splash"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_splash_to_dashboard"
            app:destination="@+id/nav_dashboard"
            app:popUpTo="@+id/nav_splash"
            app:popUpToInclusive="true"/>
    </fragment>

    <!-- Login -->
    <fragment
        android:id="@+id/nav_login"
        android:name="com.example.stashed.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@+id/nav_register"/>
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@+id/nav_dashboard"
            app:popUpTo="@+id/nav_login"
            app:popUpToInclusive="true"/>
    </fragment>

    <!-- Register -->
    <fragment
        android:id="@+id/nav_register"
        android:name="com.example.stashed.ui.auth.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_dashboard"
            app:destination="@+id/nav_dashboard"
            app:popUpTo="@+id/nav_login"
            app:popUpToInclusive="true"/>
    </fragment>

    <!-- Dashboard (bottom nav home) -->
    <fragment
        android:id="@+id/nav_dashboard"
        android:name="com.example.stashed.ui.dashboard.DashboardFragment"
        android:label="@string/nav_dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboard_to_addExpense"
            app:destination="@+id/nav_addExpense"/>
    </fragment>

    <!-- Add Expense -->
    <fragment
        android:id="@+id/nav_addExpense"
        android:name="com.example.stashed.ui.expense.AddExpenseFragment"
        android:label="Add Expense"
        tools:layout="@layout/fragment_add_expense"/>

    <!-- Budgets -->
    <fragment
        android:id="@+id/nav_budgets"
        android:name="com.example.stashed.ui.budget.BudgetFragment"
        android:label="@string/nav_budgets"
        tools:layout="@layout/fragment_budgets">
        <action
            android:id="@+id/action_budgets_to_addCategory"
            app:destination="@+id/nav_addCategory"/>
    </fragment>

    <!-- Add Category -->
    <fragment
        android:id="@+id/nav_addCategory"
        android:name="com.example.stashed.ui.budget.AddCategoryFragment"
        android:label="Add Category"
        tools:layout="@layout/fragment_add_category"/>

    <!-- Goals -->
    <fragment
        android:id="@+id/nav_goals"
        android:name="com.example.stashed.ui.goals.GoalsFragment"
        android:label="@string/nav_goals"
        tools:layout="@layout/fragment_goals">
        <action
            android:id="@+id/action_goals_to_addGoal"
            app:destination="@+id/nav_addGoal"/>
    </fragment>

    <!-- Add Goal -->
    <fragment
        android:id="@+id/nav_addGoal"
        android:name="com.example.stashed.ui.goals.AddGoalFragment"
        android:label="Add Goal"
        tools:layout="@layout/fragment_add_goal"/>

    <!-- Reports -->
    <fragment
        android:id="@+id/nav_reports"
        android:name="com.example.stashed.ui.reports.ReportsFragment"
        android:label="@string/nav_reports"
        tools:layout="@layout/fragment_reports"/>

    <!-- Settings -->
    <fragment
        android:id="@+id/nav_settings"
        android:name="com.example.stashed.ui.settings.SettingsFragment"
        android:label="@string/nav_settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settings_to_login"
            app:destination="@+id/nav_login"
            app:popUpTo="@+id/mobile_navigation"
            app:popUpToInclusive="true"/>
    </fragment>
</navigation>