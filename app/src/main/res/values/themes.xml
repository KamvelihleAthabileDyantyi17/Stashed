<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Stashed" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/red_primary</item>
        <item name="colorPrimaryVariant">@color/red_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/black_bg</item>
        <item name="android:statusBarColor">@color/black_bg</item>
        <item name="android:navigationBarColor">@color/black_bg</item>
    </style>
    <style name="Theme.Stashed.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="Theme.Stashed.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="Widget.Stashed.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/red_primary</item>
        <item name="hintTextColor">@color/red_primary</item>
    </style>

    <style name="Widget.Stashed.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/red_primary</item>
    </style>
</resources>